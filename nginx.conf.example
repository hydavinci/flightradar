# Nginx configuration example for Flight Radar
# Copy to /etc/nginx/sites-available/flight-radar and adjust server_name

server {
    listen 80;
    listen 443 ssl;
    server_name flightradar.example.com;  # <-- Change to your domain

    # SSL certificate (self-signed for Cloudflare origin, or Let's Encrypt)
    ssl_certificate /etc/nginx/ssl/flightradar.crt;
    ssl_certificate_key /etc/nginx/ssl/flightradar.key;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
